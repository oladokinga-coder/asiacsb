DATABASE_URL="file:./dev.db"
# Google Sheets (опционально): создайте сервисный аккаунт в Google Cloud,
# скачайте JSON и укажите ID таблицы. Делитесь таблицей с email сервисного аккаунта.
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Письмо об успешной регистрации (опционально). Реальные значения — в .env (не коммитить!).
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=info@asiacsb.online
SMTP_PASS=
MAIL_FROM=info@asiacsb.online

# Защита API добавления транзакции и крона писем (опционально). Если задано, в запросе нужен заголовок x-admin-secret или x-cron-secret.
# ADMIN_SECRET=
# CRON_SECRET=
